# Скопируйте в .env и заполните. Файл .env не коммитится.
DB_NAME=housing
DB_USER=housing_app
DB_PASSWORD=замените_на_сложный_пароль
DB_HOST=postgres
DB_PORT=5432
HOST_PORT=8000

# Токен dev-режима Vault (только для локальной разработки)
VAULT_TOKEN=housing-dev-root

